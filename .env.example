# =====================================================
# AI Empire Pro V8
# Environment Configuration
# =====================================================

# -----------------------------------------------------
# Application
# -----------------------------------------------------

APP_NAME=AI Empire Pro
APP_VERSION=8.0.0
NODE_ENV=development

HOST=0.0.0.0
PORT=3000

APP_SECRET=CHANGE_ME_TO_A_RANDOM_SECRET
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_JWT_SECRET

# -----------------------------------------------------
# MongoDB
# -----------------------------------------------------

MONGODB_URI=mongodb://127.0.0.1:27017/aiempire

# -----------------------------------------------------
# OpenAI
# -----------------------------------------------------

OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_MODEL=gpt-4.1

# -----------------------------------------------------
# Telegram
# -----------------------------------------------------

TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# -----------------------------------------------------
# Binance
# -----------------------------------------------------

BINANCE_API_KEY=
BINANCE_API_SECRET=

# -----------------------------------------------------
# CoinGecko
# -----------------------------------------------------

COINGECKO_API_KEY=

# -----------------------------------------------------
# SMTP
# -----------------------------------------------------

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASSWORD=password
SMTP_FROM=AI Empire Pro <noreply@example.com>

# -----------------------------------------------------
# CORS
# -----------------------------------------------------

CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# -----------------------------------------------------
# Uploads
# -----------------------------------------------------

MAX_UPLOAD_SIZE=524288000

# -----------------------------------------------------
# WebSocket
# -----------------------------------------------------

WS_PORT=3001

# -----------------------------------------------------
# Logging
# -----------------------------------------------------

LOG_LEVEL=info

# -----------------------------------------------------
# Backup
# -----------------------------------------------------

BACKUP_ENABLED=true
BACKUP_INTERVAL=24

# -----------------------------------------------------
# Trading
# -----------------------------------------------------

DEFAULT_SYMBOL=BTCUSDT
DEFAULT_CURRENCY=EUR
PAPER_TRADING=true
